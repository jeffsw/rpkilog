#cloud-config
%{~ if fqdn != null }
fqdn: ${fqdn}
prefer_fqdn_over_hostname: true
%{~ endif }
apt:
  sources:
    docker.list:
      source: "deb [arch=amd64] https://download.docker.com/linux/ubuntu $RELEASE stable"
      keyid: 7EA0A9C3F273FCD8
bootcmd:
  - |
    sz=$(lsblk -b -d -n -o SIZE /dev/vda 2>/dev/null | awk '{print $1+0}')
    if [ "$${sz:-0}" -lt 700000000000 ]; then
      echo "cloud-init ABORT: /dev/vda is $${sz} bytes, expected >= 700GB (800GiB data disk). Disk assignment is wrong." | tee /dev/kmsg
      systemctl poweroff --no-block
      sleep 10
    fi
disk_setup:
  # The Incus storage volume uses io.bus = "virtio-blk" so it appears as /dev/vda,
  # separate from the OS disk (/dev/sda via virtio-scsi).  No ordering ambiguity.
  /dev/vda:
    layout: true
    overwrite: false
    table_type: gpt
fs_setup:
  - device: /dev/vda1
    filesystem: ext4
    label: opensearch-1-dat
    overwrite: false
mounts:
  - [/dev/vda1, /data]
package_reboot_if_required: true
package_update: true
package_upgrade: true
packages:
  - bzip2
  - ca-certificates
  - curl
  - docker-ce
  - docker-ce-cli
  - htop
  - incus-agent
  - openssh-server
  - python3-bcdoc
  - python3-boto3
  - python3-botocore
  - python3-full
  - python3-pip
  - python3-venv
  - run-one
  - ssh-import-id
  - unzip
runcmd:
  # ensure /home/rpkilog/.aws and other directories we may be creating with cloud-init have correct ownership
  - "chown -R rpkilog:rpkilog /home/rpkilog"
ssh_pwauth: false
users:
  - name: opensearch
    # uid 1000 matches the opensearch user inside the opensearchproject/opensearch container image,
    # so host-side chown/chmod on /data/opensearch reflects correctly inside the container.
    uid: 1000
    gid: 1000
    shell: /usr/sbin/nologin
    lock_passwd: true
    system: true
  - name: jsw
    groups: adm,docker,sudo
    lock_passwd: false
    plain_text_passwd: "${console_password_plaintext}"
    shell: /usr/bin/bash
    sudo: "ALL=(ALL) NOPASSWD: ALL"
    ssh_authorized_keys:
      - ssh-rsa  jeffsw6@gmail.com boomer 2013-05-28
  - name: rpkilog
    shell: /usr/bin/bash
write_files:
  - path: /root/.aws/config
    owner: root:root
    permissions: '0600'
    content: |4
        [default]
        region = us-east-1
  - path: /root/.aws/credentials
    owner: root:root
    permissions: '0600'
    content: |4
        [default]
        aws_access_key_id = ${key_manager_aws_access_key_id}
        aws_secret_access_key = ${key_manager_aws_secret_access_key}
        aws_session_token = ${key_manager_aws_session_token}
  - path: /usr/local/bin/100_aws_key_manager.py
    permissions: "0755"
    content: |4
        ${indent(8, file(script_key_manager))}
  - path: /var/lib/cloud/scripts/per-once/100_install_rpkilog.sh
    permissions: "0755"
    content: |4
        ${indent(8, file(script_install_rpkilog))}
  - path: /home/rpkilog/.aws/config
    defer: true
    owner: rpkilog:rpkilog
    permissions: '0600'
    content: |4
        [default]
        region = us-east-1
  - path: /var/lib/cloud/scripts/per-once/100_aws_key_manager_wrapper.sh
    defer: true
    permissions: "0755"
    content: |4
        #!/bin/bash -e
        /usr/local/bin/100_aws_key_manager.py \
          --username ${opensearch_1_iam_username} \
          --cred-file-path /home/rpkilog/.aws/credentials \
          --cred-file-owner rpkilog \
          --cred-file-group rpkilog
  - path: /etc/profile.d/rpkilog_prompt.sh
    permissions: '0644'
    content: |4
        PS1='\u@\H:\w\$ '
  - path: /usr/local/bin/install_opensearch.sh
    permissions: "0755"
    content: |4
        ${indent(8, file(script_install_opensearch))}
  - path: /var/lib/cloud/scripts/per-once/100_install_opensearch.sh
    permissions: "0755"
    content: |4
        #!/bin/bash -e
        export OPENSEARCH_INITIAL_ADMIN_PASSWORD='${opensearch_admin_password}'
        /usr/local/bin/install_opensearch.sh
  - path: /etc/cron.d/diff_import_from_sqs
    owner: root:root
    permissions: '0644'
    content: |4
        ES_USERNAME=${diff_import_es_username}
        ES_PASSWORD=${diff_import_es_password}
        */5 * * * * rpkilog run-one /opt/rpkilog/venv/bin/rpkilog-diff-import-from-sqs --sqs-name diff_dev --es-endpoint localhost:9200 --dry-run 2>&1 | logger -t diff_import_from_sqs
